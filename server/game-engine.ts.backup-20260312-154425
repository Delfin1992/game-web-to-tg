  state.gramBalance = Number(Math.max(0, state.gramBalance - normalizedGram).toFixed(2));
  notices.push(`рџЄ™ ${reason}: -${normalizedGram} GRM`);
  return { user: context.user, state, notices, amountGram: normalizedGram };
}

