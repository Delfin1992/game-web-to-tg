  if (/^\d+$/.test(trimmed)) {
    const index = Number(trimmed) - 1;
    if (index >= 0 && index < SHOP_ITEMS.length) return SHOP_ITEMS[index];
    return null;
  }

  return SHOP_ITEMS.find((item) => item.id === trimmed) ?? null;
}

function findJobByRef(city: string, ref: string) {
  const normalizedCity = normalizeCityForLegacyMaps(city);
  const jobs = JOBS_BY_CITY[normalizedCity] ?? [];
  const trimmed = ref.trim();
  if (!trimmed) return null;

  if (/^\d+$/.test(trimmed)) {
    const index = Number(trimmed) - 1;
    if (index >= 0 && index < jobs.length) return jobs[index];
    return null;
  }

  return jobs.find((job) => job.name.toLowerCase() === trimmed.toLowerCase()) ?? null;
}

function findBankProgramByRef(type: BankProductType, ref: string) {
  const programs = type === "credit" ? CREDIT_PROGRAMS : DEPOSIT_PROGRAMS;
  const trimmed = ref.trim();
  if (!trimmed) return null;

  if (/^\d+$/.test(trimmed)) {
    const index = Number(trimmed) - 1;
    if (index >= 0 && index < programs.length) return programs[index];
    return null;
  }

  return programs.find((program) => program.name.toLowerCase() === trimmed.toLowerCase()) ?? null;
}

function resolveCityBonus(user: User): CityBonus {
  const rep = user.reputation;
  const city = user.city;
  const bonus: CityBonus = { failureRateReduction: 0, salaryBoost: 0, skillGrowthBoost: 0, xpBoost: 0 };

  if (city === "РЎР°РЅРєС‚-РџРµС‚РµСЂР±СѓСЂРі") {
    if (rep >= 100) bonus.failureRateReduction = 10;
    if (rep >= 300) bonus.skillGrowthBoost = 5;
    if (rep >= 600) bonus.failureRateReduction = 20;
    if (rep >= 1000) bonus.failureRateReduction = 25;
  }

  if (city === "РЎР°РЅ-Р¤СЂР°РЅС†РёСЃРєРѕ") {
    if (rep >= 100) bonus.salaryBoost = 8;
    if (rep >= 300) bonus.xpBoost = 12;
    if (rep >= 600) bonus.salaryBoost = 12;
    if (rep >= 1000) bonus.salaryBoost = 15;
  }

  if (city === "РЎРёРЅРіР°РїСѓСЂ") {
    if (rep >= 100) bonus.failureRateReduction = 15;
    if (rep >= 300) bonus.salaryBoost = 6;
    if (rep >= 600) bonus.failureRateReduction = 18;
    if (rep >= 1000) bonus.skillGrowthBoost = 9;
  }

  if (city === "РЎРµСѓР»") {
    if (rep >= 100) bonus.salaryBoost = 10;
    if (rep >= 300) bonus.skillGrowthBoost = 7;
    if (rep >= 600) bonus.xpBoost = 5;
    if (rep >= 1000) bonus.failureRateReduction = 30;
  }

  return bonus;
}

function applyExperience(user: User, gain: number) {
  let level = user.level;
  let experience = user.experience + gain;

  while (experience >= 100) {
    level += 1;
    experience -= 100;
  }

  return { level, experience };
}

function getOrCreateState(userId: string): GameState {
  const current = playerGameStateByUserId.get(userId);
  if (current) {
    if (!Number.isFinite(Number((current as any).gramBalance))) {
      current.gramBalance = 0;
    }
    return current;
  }

  const created = getDefaultGameState();
  playerGameStateByUserId.set(userId, created);
  return created;
}

async function advanceState(user: User, state: GameState): Promise<GameTickResult> {
  const now = Date.now();
  const elapsedSeconds = Math.max(0, Math.floor((now - state.lastTickAt) / 1000));
  state.lastTickAt = now;

  const notices: string[] = [];
  if (elapsedSeconds <= 0) return { user, notices };

  state.workTime = Math.min(1, Number((state.workTime + elapsedSeconds * ENERGY_REGEN_PER_SECOND).toFixed(4)));
  state.studyTime = Math.min(1, Number((state.studyTime + elapsedSeconds * ENERGY_REGEN_PER_SECOND).toFixed(4)));

  if (!state.activeBankProduct) return { user, notices };

  const nextDaysLeft = state.activeBankProduct.daysLeft - elapsedSeconds / 60;
  if (nextDaysLeft > 0) {
    state.activeBankProduct.daysLeft = nextDaysLeft;
    return { user, notices };
  }

  const completedProduct = state.activeBankProduct;
  state.activeBankProduct = null;

  if (completedProduct.type === "deposit") {
    const updated = await storage.updateUser(user.id, {
      balance: user.balance + Math.round(completedProduct.totalReturn),
    });
    notices.push(`вњ… Р’РєР»Р°Рґ Р·Р°РІРµСЂС€РµРЅ: +${getCurrencySymbol(updated.city)}${Math.round(completedProduct.totalReturn)}`);
    return { user: updated, notices };
  }

  const creditDue = Math.round(completedProduct.totalReturn);
  if (user.balance >= creditDue) {
    const updated = await storage.updateUser(user.id, {
      balance: user.balance - creditDue,
    });
    notices.push(`вњ… РљСЂРµРґРёС‚ Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё РїРѕРіР°С€РµРЅ: -${getCurrencySymbol(updated.city)}${creditDue}`);
    return { user: updated, notices };
  }

  const updated = await storage.updateUser(user.id, {
    balance: 0,
    reputation: Math.max(0, user.reputation - 25),
  });
  notices.push("вљ пёЏ РќРµРґРѕСЃС‚Р°С‚РѕС‡РЅРѕ СЃСЂРµРґСЃС‚РІ РґР»СЏ РїРѕРіР°С€РµРЅРёСЏ РєСЂРµРґРёС‚Р°. Р‘Р°Р»Р°РЅСЃ РѕР±РЅСѓР»РµРЅ, СЂРµРїСѓС‚Р°С†РёСЏ СЃРЅРёР¶РµРЅР°.");
  return { user: updated, notices };
}

async function loadContext(userId: string) {
