function repairMojibake(input: string) {
  if (!input) return input;
  const tokenScore = (token: string) => {
    const asciiOnly = /^[\x00-\x7F]+$/.test(token);
    if (asciiOnly) return 0;
    const cyr = (token.match(/[А-Яа-яЁё]/g) ?? []).length;
    const emoji = (token.match(/\p{Extended_Pictographic}/gu) ?? []).length;
    const commonBigrams = (token.match(/(ст|но|ен|то|на|ов|ни|ра|ко|по|ер|пр|ли|го|во|ка|ть|ая|ий|ый)/gi) ?? []).length;
    const bad = (token.match(/[�\u0000-\u001F\u007F-\u009F]/g) ?? []).length;
    const markers = (token.match(/(рџ|вЂ|в„|вљ|вњ|вќ|[РС][^A-Za-z0-9\s])/g) ?? []).length;
    return cyr * 2 + emoji * 2 + commonBigrams * 3 - bad * 6 - markers * 3;
  };
  const tryRepairToken = (token: string) => {
    if (!token || /^[\s]+$/.test(token) || /^[\x00-\x7F]+$/.test(token)) return token;
    const forceDecode = /(рџ|вЂ|в„|вљ|вњ|вќ|[РС][^\s]{2,}|пїЅ)/.test(token);
    try {
      const candidates = [token];
      const win1251Candidate = iconv.decode(iconv.encode(token, "win1251"), "utf8");
      if (win1251Candidate && !win1251Candidate.includes("�")) candidates.push(win1251Candidate);

      // Fallback for mixed mojibake/control chars (e.g. "Р..."): keep low bytes and decode as UTF-8.
      const rawBytes = Buffer.from(Array.from(token, (ch) => ch.charCodeAt(0) & 0xff));
      const byteCandidate = rawBytes.toString("utf8");
      if (byteCandidate && !byteCandidate.includes("�")) candidates.push(byteCandidate);

      const best = candidates.sort((a, b) => tokenScore(b) - tokenScore(a))[0] ?? token;
      if (forceDecode && best === token && candidates.length > 1) return candidates[1];
      return best;
    } catch {
      return token;
    }
  };

  // Keep whitespace/punctuation boundaries stable while repairing only suspicious chunks.
  return input.replace(/[^\s]+/g, (token) => tryRepairToken(token));
}

function normalizeCommand(rawText: string) {
  const repaired = repairMojibake(rawText);
  const [rawCommand, ...args] = repaired.trim().split(/\s+/);
  const command = rawCommand.split("@")[0].toLowerCase().replace(/[.,!?;:]+$/g, "");
  return { command, args };
}

