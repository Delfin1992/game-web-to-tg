        token,
        chatId,
        `вќЊ РќРµРґРѕСЃС‚Р°С‚РѕС‡РЅРѕ СЃСЂРµРґСЃС‚РІ. РќСѓР¶РЅРѕ ${getCurrencySymbol(player.city)}${course.cost}.`,
      );
      pendingActionByChatId.delete(chatId);
      return true;
    }

    const failReduction = getEducationFailureReduction(player.city, player.reputation || 0);
    const effectiveFailure = Math.max(0, course.failureChance - failReduction);
    const success = Math.random() * 100 > effectiveFailure;

    if (!success) {
      pendingActionByChatId.delete(chatId);
      await sendWithMainKeyboard(
        token,
        chatId,
        [
          `вќЊ РџСЂРѕРІР°Р» РѕР±СѓС‡РµРЅРёСЏ: ${course.icon} ${course.name}`,
          `Р РёСЃРє: ${effectiveFailure}%`,
          "РћРїР»Р°С‚Р° РЅРµ СЃРїРёСЃР°РЅР°. РџРѕРїСЂРѕР±СѓР№ СЃРЅРѕРІР°: рџ“љ РЈС‡С‘Р±Р°",
        ].join("\n"),
      );
      return true;
    }

    const updatedUser = await storage.updateUser(player.id, {
      balance: player.balance - course.cost,
      reputation: (player.reputation || 0) + 3,
    });

    const snapshot = await getUserWithGameState(player.id);
    const game = snapshot?.game as GameView;
    const nextSkills = { ...(game?.skills || {}) } as Record<SkillName, number>;
    for (const [key, boost] of Object.entries(course.skillBoosts)) {
      if (!(key in nextSkills)) continue;
      const skill = key as SkillName;
      nextSkills[skill] = Number((nextSkills[skill] + Number(boost)).toFixed(2));
    }

    applyGameStatePatch(player.id, { skills: nextSkills });
    const refreshed = await getUserWithGameState(player.id);
    const tutorialEvent = await tryApplyTutorialEvent(player.id, "first_education_started");
    const questProgress = updateWeeklyQuestProgress(updatedUser, "study", 1);
    pendingActionByChatId.delete(chatId);

    if (!refreshed) {
      await sendWithMainKeyboard(token, chatId, "вњ… РљСѓСЂСЃ Р·Р°РІРµСЂС€С‘РЅ, РЅРѕ РЅРµ СѓРґР°Р»РѕСЃСЊ РѕР±РЅРѕРІРёС‚СЊ РїСЂРѕС„РёР»СЊ.");
      return true;
    }

    await sendWithMainKeyboard(
      token,
      chatId,
      [
        `вњ… РљСѓСЂСЃ Р·Р°РІРµСЂС€С‘РЅ: ${course.icon} ${course.name}`,
        `-${getCurrencySymbol(updatedUser.city)}${course.cost}, +3 СЂРµРїСѓС‚Р°С†РёРё`,
        `РќР°РІС‹РєРё: ${formatStats(course.skillBoosts as Record<string, number>)}`,
        formatTutorialAdvanceNotice(tutorialEvent),
        formatWeeklyQuestProgressNotice(questProgress),
        "",
        await formatPlayerProfile(refreshed),
      ].filter(Boolean).join("\n"),
    );
    return true;
  }

  if (pendingAction.type === "admin_auth") {
    pendingActionByChatId.delete(chatId);
    if (text.trim() !== ADMIN_PASSWORD) {
      await sendWithMainKeyboard(token, chatId, "вќЊ РќРµРІРµСЂРЅС‹Р№ РїР°СЂРѕР»СЊ Р°РґРјРёРЅРёСЃС‚СЂР°С‚РѕСЂР°.");
      return true;
    }

    adminAuthByChatId.set(chatId, true);
    await sendWithAdminKeyboard(
      token,
      chatId,
      [
        "рџ›  РђРґРјРёРЅ-СЂРµР¶РёРј РІРєР»СЋС‡РµРЅ.",
        "Р”РѕСЃС‚СѓРїРЅРѕ:",
        "вЂў Р’С‹РґР°С‡Р° РґРµРЅРµРі",
        "вЂў Р’С‹РґР°С‡Р° РѕРїС‹С‚Р°",
        "вЂў РЎР±СЂРѕСЃ РёРіСЂРѕРєР° / СЂРµСЃС‚Р°СЂС‚",
      ].join("\n"),
    );
    return true;
  }

  if (pendingAction.type === "admin_add_money") {
    pendingActionByChatId.delete(chatId);
    if (!adminAuthByChatId.get(chatId)) {
      await sendWithMainKeyboard(token, chatId, "вќЊ РЎРЅР°С‡Р°Р»Р° Р°РІС‚РѕСЂРёР·СѓР№СЃСЏ: /admin <РїР°СЂРѕР»СЊ>");
      return true;
    }

    const amount = Number(text.trim());
    if (!Number.isFinite(amount) || amount <= 0) {
      await sendWithAdminKeyboard(token, chatId, "Р’РІРµРґРёС‚Рµ РєРѕСЂСЂРµРєС‚РЅСѓСЋ СЃСѓРјРјСѓ > 0.");
      return true;
    }

    const updated = await storage.updateUser(player.id, {
      balance: player.balance + Math.floor(amount),
    });
    const refreshed = await getUserWithGameState(updated.id);
    await sendWithAdminKeyboard(
      token,
      chatId,
      refreshed
        ? `вњ… Р’С‹РґР°РЅРѕ ${getCurrencySymbol(updated.city)}${Math.floor(amount)}\n\n${await formatPlayerProfile(refreshed)}`
        : `вњ… Р’С‹РґР°РЅРѕ ${getCurrencySymbol(updated.city)}${Math.floor(amount)}`,
    );
    return true;
  }

  if (pendingAction.type === "admin_add_exp") {
    pendingActionByChatId.delete(chatId);
    if (!adminAuthByChatId.get(chatId)) {
      await sendWithMainKeyboard(token, chatId, "вќЊ РЎРЅР°С‡Р°Р»Р° Р°РІС‚РѕСЂРёР·СѓР№СЃСЏ: /admin <РїР°СЂРѕР»СЊ>");
      return true;
    }

    const amount = Number(text.trim());
    if (!Number.isFinite(amount) || amount <= 0) {
      await sendWithAdminKeyboard(token, chatId, "Р’РІРµРґРёС‚Рµ РєРѕСЂСЂРµРєС‚РЅРѕРµ Р·РЅР°С‡РµРЅРёРµ РѕРїС‹С‚Р° > 0.");
      return true;
    }

    const next = applyExperienceGain(player, Math.floor(amount));
    const updated = await storage.updateUser(player.id, {
      level: next.level,
      experience: next.experience,
    });
    const refreshed = await getUserWithGameState(updated.id);
    await sendWithAdminKeyboard(
      token,
      chatId,
      refreshed
        ? `вњ… РќР°С‡РёСЃР»РµРЅРѕ ${Math.floor(amount)} XP\n\n${await formatPlayerProfile(refreshed)}`
        : `вњ… РќР°С‡РёСЃР»РµРЅРѕ ${Math.floor(amount)} XP`,
    );
    return true;
  }

  if (pendingAction.type === "company_create") {
    const companyName = text.trim();
    if (companyName.length < 3) {
      await sendMessage(token, chatId, "РќР°Р·РІР°РЅРёРµ СЃР»РёС€РєРѕРј РєРѕСЂРѕС‚РєРѕРµ. РњРёРЅРёРјСѓРј 3 СЃРёРјРІРѕР»Р°.");
      return true;
    }

    const membership = await getPlayerCompanyContext(player.id);
    if (membership) {
      pendingActionByChatId.delete(chatId);
      await sendWithMainKeyboard(token, chatId, "РўС‹ СѓР¶Рµ СЃРѕСЃС‚РѕРёС€СЊ РІ РєРѕРјРїР°РЅРёРё. РСЃРїРѕР»СЊР·СѓР№ /company.");
      return true;
    }

    if (player.balance < COMPANY_CREATE_COST) {
      await sendMessage(
        token,
        chatId,
        `РќРµРґРѕСЃС‚Р°С‚РѕС‡РЅРѕ СЃСЂРµРґСЃС‚РІ РґР»СЏ СЃРѕР·РґР°РЅРёСЏ РєРѕРјРїР°РЅРёРё. РќСѓР¶РЅРѕ ${getCurrencySymbol(player.city)}${COMPANY_CREATE_COST}.`,
      );
      return true;
    }

    let debited: User | null = null;
    try {
      debited = await storage.updateUser(player.id, {
        balance: player.balance - COMPANY_CREATE_COST,
      });
      const company = await storage.createCompany(
        { name: companyName.slice(0, 40), city: player.city },
        player.id,
        player.username,
      );
      const members = await storage.getCompanyMembers(company.id);
      await ensureCompanyEconomyState(company, members.length);
      pendingActionByChatId.delete(chatId);
      await sendWithMainKeyboard(
        token,
        chatId,
        `вњ… РљРѕРјРїР°РЅРёСЏ СЃРѕР·РґР°РЅР°: ${company.name}\nРЎРїРёСЃР°РЅРѕ: ${getCurrencySymbol(player.city)}${COMPANY_CREATE_COST}\nРћСЃС‚Р°С‚РѕРє: ${getCurrencySymbol(player.city)}${debited.balance}\nРћС‚РєСЂРѕР№ /profile вЂ” С‚С‹ С‚РµРїРµСЂСЊ CEO.`,
      );
    } catch (error) {
      if (debited) {
        await storage.updateUser(player.id, { balance: debited.balance + COMPANY_CREATE_COST });
      }
      await sendMessage(token, chatId, `вќЊ ${extractErrorMessage(error)}`);
    }
    return true;
  }

  return false;
}

async function handleIncomingCallback(token: string, webAppUrl: string, query: TelegramCallbackQuery) {
  const callbackId = query.id;
  const chatId = query.message?.chat?.id;
  const data = (query.data || "").trim();
  let callbackText = "Р“РѕС‚РѕРІРѕ";

  try {
    if (!chatId || !data) {
      callbackText = "РќРµРєРѕСЂСЂРµРєС‚РЅР°СЏ РєРЅРѕРїРєР°";
      return;
    }

    if (data === "inv:open") {
      callbackText = "РРЅРІРµРЅС‚Р°СЂСЊ";
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: "/inventory",
      });
      return;
    }

    const inventoryActionMatch = data.match(/^inv:(use|equip|service):(\d+)$/);
    if (inventoryActionMatch) {
      const action = inventoryActionMatch[1];
      const index = inventoryActionMatch[2];
      callbackText = "РРЅРІРµРЅС‚Р°СЂСЊ";
      const command = action === "use"
        ? `/use ${index}`
        : action === "equip"
        ? `/equip ${index}`
        : `/service ${index}`;
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: command,
      });
      return;
    }

    if (data === "quest:refresh") {
      callbackText = "РљРІРµСЃС‚С‹";
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: "/quests",
      });
      return;
    }

    if (data === "quest:claim") {
      callbackText = "РќР°РіСЂР°РґР° РєРІРµСЃС‚Р°";
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: "/quest_claim",
      });
      return;
    }

    if (data === "quest:reputation") {
      callbackText = "Р РµРїСѓС‚Р°С†РёСЏ";
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: "/reputation",
      });
      return;
    }

    if (data === "quest:rating") {
      callbackText = "Р РµР№С‚РёРЅРі";
      await handleIncomingMessage(token, webAppUrl, {
        chat: { id: chatId },
        from: query.from,
        text: "/rating",
      });
      return;
    }

    const ratingMatch = data.match(/^rating:(players|companies):(level|reputation|wealth|blueprints)$/);
    if (ratingMatch) {
      callbackText = "Р РµР№С‚РёРЅРі";
      const entity = normalizeRatingEntity(ratingMatch[1]);
      const sortValue = ratingMatch[2];
      const ratingMenu = await formatRatingMenu(entity, sortValue);
      const messageId = query.message?.message_id;
      if (messageId) {
        await callTelegramApi(token, "editMessageText", {
          chat_id: chatId,
          message_id: messageId,
          text: ratingMenu.text,
          reply_markup: buildRatingInlineButtons(ratingMenu.entity, ratingMenu.sort),
        });
      } else {
        await sendMessage(token, chatId, ratingMenu.text, {
          reply_markup: buildRatingInlineButtons(ratingMenu.entity, ratingMenu.sort),
        });
      }
      return;
    }

    if (data.startsWith("tutorial:")) {
      const player = await resolveOrCreateTelegramPlayer(query.from);

      if (data === "tutorial:refresh") {
        callbackText = "РћР±РЅРѕРІР»РµРЅРѕ";
        await sendTutorialMenu(token, chatId, player.id);
        return;
      }

      if (data === "tutorial:start") {
