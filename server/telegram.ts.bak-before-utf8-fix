  }

  if (pendingAction.type === "study_level_select") {
    const levelKey = resolveEducationLevel(text, player.level);
    if (!levelKey) {
      await sendMessage(
        token,
        chatId,
        "РќРµ РїРѕРЅСЏР» СѓСЂРѕРІРµРЅСЊ РѕР±СѓС‡РµРЅРёСЏ. Р’С‹Р±РµСЂРё РёР· СЃРїРёСЃРєР°: РЁРєРѕР»Р° / РљРѕР»Р»РµРґР¶ / РЈРЅРёРІРµСЂСЃРёС‚РµС‚.",
