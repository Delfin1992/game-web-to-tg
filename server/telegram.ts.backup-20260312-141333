function resolveRegistrationStepFromValues(values: {
  username?: string;
  city?: string;
  personality?: string;
  gender?: string;
}): RegistrationStep | null {
  if (!isRegistrationUsernameFilled(values.username)) return "register_username";
  if (!isValidRegistrationCity(values.city)) return "register_city";
  if (!isValidRegistrationPersonality(values.personality)) return "register_personality";
  if (!isValidRegistrationGender(values.gender)) return "register_gender";
  return null;
}

function resolveTelegramRegistrationStep(user: User, chatId: number): RegistrationStep | null {
  const pendingAction = pendingActionByChatId.get(chatId);
  if (
    pendingAction?.type === "register_username"
    || pendingAction?.type === "register_city"
    || pendingAction?.type === "register_personality"
    || pendingAction?.type === "register_gender"
  ) {
    return pendingAction.type;
  }
  if (!isTelegramRegistrationCompleted(user)) return "register_username";
  return resolveRegistrationStepFromValues({
    username: user.username,
    city: user.city,
    personality: user.personality,
    gender: user.gender,
  });
}

async function sendTelegramRegistrationStepPrompt(token: string, chatId: number, step: RegistrationStep) {
  if (step === "register_city") {
    await sendMessage(token, chatId, formatCitySelectionMessage(), { reply_markup: REGISTRATION_CITY_REPLY_MARKUP });
    return;
  }

  if (step === "register_personality") {
    await sendMessage(token, chatId, formatPersonalitySelectionMessage(), {
      reply_markup: REGISTRATION_PERSONALITY_REPLY_MARKUP,
    });
    return;
  }

  if (step === "register_gender") {
    await sendMessage(token, chatId, formatGenderSelectionMessage(), {
      reply_markup: REGISTRATION_GENDER_REPLY_MARKUP,
    });
    return;
  }

  await sendMessage(
    token,
    chatId,
    [
      "🆕 Регистрация игрока",
      "1/4. Впиши ник игрока (3-24 символа).",
      "Разрешены буквы, цифры, пробел, _ и -",
    ].join("\n"),
    { reply_markup: { remove_keyboard: true } },
  );
}

