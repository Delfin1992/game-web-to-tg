    .sort((a, b) => {
      const econA = reconcileCompanyEconomy(a as CompanyEconomyLike);
      const econB = reconcileCompanyEconomy(b as CompanyEconomyLike);
      return (econB.companyLevel - econA.companyLevel) || (econB.capitalGRM - econA.capitalGRM);
    })
    .slice(0, 8);
}

