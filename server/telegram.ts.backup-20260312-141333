    if (pendingAction.type === "register_personality") {
      const personality = resolvePersonality(text);
      if (!personality) {
        await sendMessage(token, chatId, "Выбери характер кнопкой ниже.", {
          reply_markup: REGISTRATION_PERSONALITY_REPLY_MARKUP,
