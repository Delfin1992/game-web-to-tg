    }

    const membership = await getPlayerCompanyContext(player.id);
    if (membership) {
      pendingActionByChatId.delete(chatId);
      await sendWithMainKeyboard(token, chatId, "–†—ě–°‚ÄĻ –°—ď–†¬∂–†¬Ķ –°–É–†—ē–°–É–°‚Äö–†—ē–†—Ď–°‚ā¨–°–ä –†–Ü –†—Ē–†—ē–†—ė–†—ó–†¬į–†–Ö–†—Ď–†—Ď. –†¬ė–°–É–†—ó–†—ē–†¬Ľ–°–ä–†¬∑–°—ď–†‚ĄĖ /company.");
      return true;
    }

    if (player.balance < COMPANY_CREATE_COST) {
      await sendMessage(
        token,
        chatId,
        `–†—ú–†¬Ķ–†“Ď–†—ē–°–É–°‚Äö–†¬į–°‚Äö–†—ē–°‚Ä°–†–Ö–†—ē –°–É–°–ā–†¬Ķ–†“Ď–°–É–°‚Äö–†–Ü –†“Ď–†¬Ľ–°–Ź –°–É–†—ē–†¬∑–†“Ď–†¬į–†–Ö–†—Ď–°–Ź –†—Ē–†—ē–†—ė–†—ó–†¬į–†–Ö–†—Ď–†—Ď. –†—ú–°—ď–†¬∂–†–Ö–†—ē ${getCurrencySymbol(player.city)}${COMPANY_CREATE_COST}.`,
