function resolveEducationLevel(input: string, userLevel: number): EducationLevelKey | null {
  const available = getAvailableEducationLevels(userLevel);
  const normalized = input.trim().toLowerCase();
  if (!normalized) return null;

  if (normalized === "1") return available[0] ?? null;
  if (normalized === "2") return available[1] ?? null;
  if (normalized === "3") return available[2] ?? null;
  if (["school", "–°‚ā¨–†—Ē–†—ē–†¬Ľ–†¬į", "—Ä—ü–Ź¬ę–°‚ā¨–†—Ē–†—ē–†¬Ľ–†¬į", "—Ä—ü–Ź¬ę –°‚ā¨–†—Ē–†—ē–†¬Ľ–†¬į"].includes(normalized)) return available.includes("school") ? "school" : null;
  if (["college", "–†—Ē–†—ē–†¬Ľ–†¬Ľ–†¬Ķ–†“Ď–†¬∂", "—Ä—ü–č‚Äú–†—Ē–†—ē–†¬Ľ–†¬Ľ–†¬Ķ–†“Ď–†¬∂", "—Ä—ü–č‚Äú –†—Ē–†—ē–†¬Ľ–†¬Ľ–†¬Ķ–†“Ď–†¬∂"].includes(normalized)) return available.includes("college") ? "college" : null;
  if (["university", "–°—ď–†–Ö–†—Ď–†–Ü–†¬Ķ–°–ā–°–É–†—Ď–°‚Äö–†¬Ķ–°‚Äö", "—Ä—ü–Ź‚Äļ–°—ď–†–Ö–†—Ď–†–Ü–†¬Ķ–°–ā–°–É–†—Ď–°‚Äö–†¬Ķ–°‚Äö", "—Ä—ü–Ź‚Äļ –°—ď–†–Ö–†—Ď–†–Ü–†¬Ķ–°–ā–°–É–†—Ď–°‚Äö–†¬Ķ–°‚Äö"].includes(normalized)) return available.includes("university") ? "university" : null;
  return null;
}

function resolveEducationCourse(levelKey: EducationLevelKey, input: string) {
  const courses = EDUCATION_LEVELS[levelKey].courses;
  const normalized = input.trim().toLowerCase();
  if (!normalized) return null;
  if (/^\d+$/.test(normalized)) {
    const index = Number(normalized) - 1;
    return index >= 0 && index < courses.length ? courses[index] : null;
  }
  return courses.find((course) => course.id === normalized || course.name.toLowerCase() === normalized) ?? null;
}

