  if (pendingAction.type === "admin_add_exp") {
    pendingActionByChatId.delete(chatId);
    if (!adminAuthByChatId.get(chatId)) {
      await sendWithMainKeyboard(token, chatId, "–≤—ú–ä –†–é–†–Ö–†¬į–°‚Ä°–†¬į–†¬Ľ–†¬į –†¬į–†–Ü–°‚Äö–†—ē–°–ā–†—Ď–†¬∑–°—ď–†‚ĄĖ–°–É–°–Ź: /admin <–†—ó–†¬į–°–ā–†—ē–†¬Ľ–°–ä>");
      return true;
    }

    const amount = Number(text.trim());
    if (!Number.isFinite(amount) || amount <= 0) {
      await sendWithAdminKeyboard(token, chatId, "–†‚Äô–†–Ü–†¬Ķ–†“Ď–†—Ď–°‚Äö–†¬Ķ –†—Ē–†—ē–°–ā–°–ā–†¬Ķ–†—Ē–°‚Äö–†–Ö–†—ē–†¬Ķ –†¬∑–†–Ö–†¬į–°‚Ä°–†¬Ķ–†–Ö–†—Ď–†¬Ķ –†—ē–†—ó–°‚ÄĻ–°‚Äö–†¬į > 0.");
