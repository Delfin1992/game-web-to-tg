    await sendMessage(token, chatId, `–≤—ö‚Ä¶ –†‚ÄĒ–†¬į–°–Ź–†–Ü–†—Ē–†¬į ${request.username} –†—ē–°‚Äö–†—Ē–†¬Ľ–†—ē–†–Ö–†¬Ķ–†–Ö–†¬į.`, {
      reply_markup: buildCompanyManagementInlineButtons(true),
    });
    return;
  }

  if (command === "/company_delete") {
    const player = await resolveOrCreateTelegramPlayer(message.from);
    const membership = await getPlayerCompanyContext(player.id);
    if (!membership || membership.role !== "owner") {
      await sendWithMainKeyboard(token, chatId, "–†—ô–†—ē–†—ė–†¬į–†–Ö–†“Ď–†¬į –†“Ď–†—ē–°–É–°‚Äö–°—ď–†—ó–†–Ö–†¬į –°‚Äö–†—ē–†¬Ľ–°–ä–†—Ē–†—ē CEO –†—Ē–†—ē–†—ė–†—ó–†¬į–†–Ö–†—Ď–†—Ď.");
      return;
    }

    await storage.deleteCompany(membership.company.id);
    companyEconomyByCompanyId.delete(String(membership.company.id));
    companySalaryByCompanyId.delete(String(membership.company.id));
    companySalaryClaimAtByCompanyId.delete(String(membership.company.id));
    stopCompanyBlueprintProgressTicker(chatId);
    companyBlueprintProgressMessageByChatId.delete(chatId);
    await sendMessage(token, chatId, `—Ä—ü‚ÄĒ‚Äė –†—ô–†—ē–†—ė–†—ó–†¬į–†–Ö–†—Ď–°–Ź "${membership.company.name}" –°—ď–†“Ď–†¬į–†¬Ľ–†¬Ķ–†–Ö–†¬į.`, {
      reply_markup: buildCompanyReplyMarkup(null),
    });
    return;
  }

  if (command === "/credits") {
    const snapshot = await resolveTelegramSnapshot(message.from);
    pendingActionByChatId.set(chatId, { type: "open_bank_product", productType: "credit" });
    await sendMessage(token, chatId, formatBankProgramsMenu("credit", snapshot), { reply_markup: buildBankSelectionReplyMarkup("credit") });
    return;
  }

  if (command === "/deposits") {
    const snapshot = await resolveTelegramSnapshot(message.from);
    pendingActionByChatId.set(chatId, { type: "open_bank_product", productType: "deposit" });
    await sendMessage(token, chatId, formatBankProgramsMenu("deposit", snapshot), { reply_markup: buildBankSelectionReplyMarkup("deposit") });
    return;
  }

  if (command === "/credit" || command === "/deposit") {
    const parsed = parseBankOpenInput(args.join(" "));
    if (!parsed) {
      await sendWithBankKeyboard(token, chatId, `–†¬ė–°–É–†—ó–†—ē–†¬Ľ–°–ä–†¬∑–†—ē–†–Ü–†¬į–†–Ö–†—Ď–†¬Ķ: ${command} <–†–Ö–†—ē–†—ė–†¬Ķ–°–ā –†—ó–°–ā–†—ē–†—Ė–°–ā–†¬į–†—ė–†—ė–°‚ÄĻ> <–°–É–°—ď–†—ė–†—ė–†¬į> <–†“Ď–†–Ö–†—Ď>\n–†—ü–°–ā–†—Ď–†—ė–†¬Ķ–°–ā: ${command} 1 10000 14`);
      return;
    }
    const player = await resolveOrCreateTelegramPlayer(message.from);
    const type: BankProductType = command === "/credit" ? "credit" : "deposit";
    try {
      const result = await openBankProduct(player.id, type, parsed.programRef, parsed.amount, parsed.days);
      await sendWithBankKeyboard(token, chatId, [type === "credit" ? `–≤—ö‚Ä¶ –†—ô–°–ā–†¬Ķ–†“Ď–†—Ď–°‚Äö –†—ē–°‚Äě–†—ē–°–ā–†—ė–†¬Ľ–†¬Ķ–†–Ö: ${result.program.name}` : `–≤—ö‚Ä¶ –†‚Äô–†—Ē–†¬Ľ–†¬į–†“Ď –†—ē–°‚Äö–†—Ē–°–ā–°‚ÄĻ–°‚Äö: ${result.program.name}`, ...result.notices, "", await formatLiveProfile(result.user, result.state as GameView)].join("\n"));
    } catch (error) {
      await sendWithBankKeyboard(token, chatId, `–≤—ú–ä ${extractErrorMessage(error)}`);
    }
    return;
  }

  if (command === "/repay" || command === "/withdraw") {
    const player = await resolveOrCreateTelegramPlayer(message.from);
    const action = command === "/repay" ? "repay" : "withdraw";
    try {
      const result = await closeBankProduct(player.id, action);
      const symbol = getCurrencySymbol(result.user.city);
      await sendWithBankKeyboard(token, chatId, [action === "repay" ? `–≤—ö‚Ä¶ –†—ô–°–ā–†¬Ķ–†“Ď–†—Ď–°‚Äö –†—ó–†—ē–†—Ė–†¬į–°‚ā¨–†¬Ķ–†–Ö: -${symbol}${Math.round(result.amount)}` : `–≤—ö‚Ä¶ –†‚Äô–†—Ē–†¬Ľ–†¬į–†“Ď –°–É–†–Ö–°–Ź–°‚Äö: +${symbol}${Math.round(result.amount)}`, ...result.notices, "", await formatLiveProfile(result.user, result.state as GameView)].join("\n"));
    } catch (error) {
      await sendWithBankKeyboard(token, chatId, `–≤—ú–ä ${extractErrorMessage(error)}`);
    }
    return;
  }

  if (command === "/city") {
    const player = await resolveOrCreateTelegramPlayer(message.from);
    const nextCity = args.join(" ").trim();
    if (!nextCity) {
      pendingActionByChatId.set(chatId, { type: "change_city" });
      await sendMessage(token, chatId, "–†‚Äô–°‚ÄĻ–†¬Ī–†¬Ķ–°–ā–†—Ď –†—Ė–†—ē–°–ā–†—ē–†“Ď:\n1) –†–é–†¬į–†–Ö–†—Ē–°‚Äö-–†—ü–†¬Ķ–°‚Äö–†¬Ķ–°–ā–†¬Ī–°—ď–°–ā–†—Ė\n2) –†–é–†¬Ķ–°—ď–†¬Ľ\n3) –†–é–†—Ď–†–Ö–†—Ė–†¬į–†—ó–°—ď–°–ā\n4) –†–é–†¬į–†–Ö-–†¬§–°–ā–†¬į–†–Ö–°‚Ä†–†—Ď–°–É–†—Ē–†—ē", { reply_markup: CITY_REPLY_MARKUP });
      return;
    }
    const resolvedCity = resolveCityName(nextCity);
    if (!resolvedCity) {
      pendingActionByChatId.set(chatId, { type: "change_city" });
      await sendMessage(token, chatId, "–†—ú–†¬Ķ –†—ó–†—ē–†–Ö–°–Ź–†¬Ľ –†—Ė–†—ē–°–ā–†—ē–†“Ď. –†‚Äô–°‚ÄĻ–†¬Ī–†¬Ķ–°–ā–†—Ď –†—Ď–†¬∑ –°–É–†—ó–†—Ď–°–É–†—Ē–†¬į:\n1) –†–é–†¬į–†–Ö–†—Ē–°‚Äö-–†—ü–†¬Ķ–°‚Äö–†¬Ķ–°–ā–†¬Ī–°—ď–°–ā–†—Ė\n2) –†–é–†¬Ķ–°—ď–†¬Ľ\n3) –†–é–†—Ď–†–Ö–†—Ė–†¬į–†—ó–°—ď–°–ā\n4) –†–é–†¬į–†–Ö-–†¬§–°–ā–†¬į–†–Ö–°‚Ä†–†—Ď–°–É–†—Ē–†—ē", { reply_markup: CITY_REPLY_MARKUP });
      return;
    }
    await storage.updateUser(player.id, { city: resolvedCity });
    pendingActionByChatId.delete(chatId);
    const snapshot = await resolveTelegramSnapshot(message.from);
    const profileText = await formatPlayerProfile(snapshot);
    const base = `—Ä—ü–Ź‚ĄĘ –†‚Äú–†—ē–°–ā–†—ē–†“Ď –†—ē–†¬Ī–†–Ö–†—ē–†–Ü–†¬Ľ–°‚Äė–†–Ö: ${snapshot.user.city}\n\n${profileText}`;
    const notices = formatNotices(snapshot.notices);
    await sendWithMainKeyboard(token, chatId, notices ? `${base}\n\n${notices}` : base);
    return;
  }

  await sendWithMainKeyboard(token, chatId, "–†—ú–†¬Ķ–†—Ď–†¬∑–†–Ü–†¬Ķ–°–É–°‚Äö–†–Ö–†¬į–°–Ź –†—Ē–†—ē–†—ė–†¬į–†–Ö–†“Ď–†¬į. –†—ú–†¬į–†—ó–†—Ď–°‚ā¨–†—Ď /help");
}

export function startTelegramBot(httpServer: Server) {
  const token = process.env.TELEGRAM_BOT_TOKEN;
  if (!token) {
    console.log("–≤‚Äě‚ĄĖ–Ņ—Ď–Ź TELEGRAM_BOT_TOKEN –†–Ö–†¬Ķ –†¬∑–†¬į–†“Ď–†¬į–†–Ö –≤–ā‚ÄĚ Telegram –†¬Ī–†—ē–°‚Äö –†–Ö–†¬Ķ –†¬∑–†¬į–†—ó–°—ď–°‚Äį–†¬Ķ–†–Ö");
    return;
  }

  const webAppUrl = trimTrailingSlash(process.env.TELEGRAM_WEBAPP_URL || process.env.APP_URL || "http://localhost:5000");
  if (!webAppUrl.startsWith("https://") && !webAppUrl.startsWith("http://localhost")) {
    console.warn(`–≤—ô¬†–Ņ—Ď–Ź TELEGRAM_WEBAPP_URL –†“Ď–†—ē–†¬Ľ–†¬∂–†¬Ķ–†–Ö –†¬Ī–°‚ÄĻ–°‚Äö–°–ä HTTPS (–°‚Äö–†¬Ķ–†—Ē–°—ď–°‚Äį–†¬Ķ–†¬Ķ –†¬∑–†–Ö–†¬į–°‚Ä°–†¬Ķ–†–Ö–†—Ď–†¬Ķ: ${webAppUrl})`);
  }

  let stopped = false;
  let offset = 0;

  const poll = async () => {
    if (stopped) return;
    try {
      const updates: Array<any> = await callTelegramApi(token, "getUpdates", {
        timeout: 25,
        offset,
        allowed_updates: ["message", "callback_query"],
      });
      for (const update of updates) {
        offset = Math.max(offset, update.update_id + 1);
        try {
          if (update?.callback_query) {
            await handleIncomingCallback(token, webAppUrl, update.callback_query as TelegramCallbackQuery);
            continue;
          }
          if (update?.message) {
            await handleIncomingMessage(token, webAppUrl, update.message as TelegramMessage);
          }
        } catch (error) {
          console.error("–≤—ô¬†–Ņ—Ď–Ź Telegram message handling error:", error);
          const messageChatId = update?.message?.chat?.id ?? update?.callback_query?.message?.chat?.id;
          if (messageChatId) {
            await sendWithMainKeyboard(token, messageChatId, "–†—õ–°‚ā¨–†—Ď–†¬Ī–†—Ē–†¬į –†—ē–†¬Ī–°–ā–†¬į–†¬Ī–†—ē–°‚Äö–†—Ē–†—Ď –†—Ē–†—ē–†—ė–†¬į–†–Ö–†“Ď–°‚ÄĻ. –†—ü–†—ē–†—ó–°–ā–†—ē–†¬Ī–°—ď–†‚ĄĖ –†¬Ķ–°‚Äį–°‚Äė –°–ā–†¬į–†¬∑.");
          }
        }
      }
    } catch (error) {
      console.error("–≤—ô¬†–Ņ—Ď–Ź Telegram polling error:", error);
      await new Promise((resolve) => setTimeout(resolve, 3000));
    }
    setImmediate(poll);
  };

  const stop = () => {
    stopped = true;
  };

  const bootstrapPolling = async () => {
    try {
      await callTelegramApi(token, "deleteWebhook", { drop_pending_updates: false });
      console.log("–≤‚Äě‚ĄĖ–Ņ—Ď–Ź Telegram webhook –†—ē–°‚Äö–†—Ē–†¬Ľ–°–č–°‚Ä°–†¬Ķ–†–Ö, –†—Ď–°–É–†—ó–†—ē–†¬Ľ–°–ä–†¬∑–°—ď–†¬Ķ–°‚Äö–°–É–°–Ź polling");
    } catch (error) {
      console.warn("–≤—ô¬†–Ņ—Ď–Ź –†—ú–†¬Ķ –°—ď–†“Ď–†¬į–†¬Ľ–†—ē–°–É–°–ä –†—ē–°‚Äö–†—Ē–†¬Ľ–°–č–°‚Ä°–†—Ď–°‚Äö–°–ä webhook, –†—ó–°–ā–†—ē–†“Ď–†—ē–†¬Ľ–†¬∂–†¬į–°–č polling:", error);
    }

    if (!telegramBotUsername) {
      try {
        const me = await callTelegramApi(token, "getMe", {});
        if (me?.username) {
          telegramBotUsername = String(me.username).replace("@", "").trim();
          console.log(`–≤‚Äě‚ĄĖ–Ņ—Ď–Ź Telegram bot username: @${telegramBotUsername}`);
        }
      } catch (error) {
        console.warn("–≤—ô¬†–Ņ—Ď–Ź –†—ú–†¬Ķ –°—ď–†“Ď–†¬į–†¬Ľ–†—ē–°–É–°–ä –†—ó–†—ē–†¬Ľ–°—ď–°‚Ä°–†—Ď–°‚Äö–°–ä username –†¬Ī–†—ē–°‚Äö–†¬į (getMe):", error);
      }
    }

    try {
      await callTelegramApi(token, "setMyCommands", { commands: TELEGRAM_PUBLIC_COMMANDS });
      console.log("–≤‚Äě‚ĄĖ–Ņ—Ď–Ź Telegram command list synced");
    } catch (error) {
      console.warn("–≤—ô¬†–Ņ—Ď–Ź –†—ú–†¬Ķ –°—ď–†“Ď–†¬į–†¬Ľ–†—ē–°–É–°–ä –†—ē–†¬Ī–†–Ö–†—ē–†–Ü–†—Ď–°‚Äö–°–ä –°–É–†—ó–†—Ď–°–É–†—ē–†—Ē –†—Ē–†—ē–†—ė–†¬į–†–Ö–†“Ď Telegram:", error);
    }

    poll();
  };

  void bootstrapPolling();

  httpServer.on("close", stop);
  process.on("SIGTERM", stop);
  process.on("SIGINT", stop);

  console.log("–≤—ö‚Ä¶ Telegram bot polling started");
}

