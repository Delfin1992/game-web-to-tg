    await sendWithAdminKeyboard(
      token,
      chatId,
      refreshed
        ? `–≤—ö‚Ä¶ –†—ú–†¬į–°‚Ä°–†—Ď–°–É–†¬Ľ–†¬Ķ–†–Ö–†—ē ${Math.floor(amount)} XP\n\n${await formatPlayerProfile(refreshed)}`
        : `–≤—ö‚Ä¶ –†—ú–†¬į–°‚Ä°–†—Ď–°–É–†¬Ľ–†¬Ķ–†–Ö–†—ē ${Math.floor(amount)} XP`,
